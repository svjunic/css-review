{
  "name": "@svjunic/css-diff",
  "version": "0.2.0",
  "description": "CSS structural diff tool — compares effective CSS properties between two files",
  "type": "module",
  "bin": {
    "css-diff": "bin/css-diff.js"
  },
  "exports": {
    ".": "./src/core/index.js"
  },
  "files": [
    "bin/",
    "src/core/",
    "src/ui/render.js",
    "src/reporters/",
    "src/styles.css",
    "README.md",
    "README/cli.md",
    "LICENSE"
  ],
  "scripts": {
