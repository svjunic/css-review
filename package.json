    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.3.0"
  },
  "keywords": [
    "css",
    "diff",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svjunic/css-diff.git"
